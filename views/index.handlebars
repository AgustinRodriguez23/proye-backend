

<p>Dejamos nuestra huella con estilo !</p>
<button id="btn">traer productos</button>

<div id="products-list">
    {{#each products}}
    <a href="/products/{{_id}}" class="product-item">
        <img src="{{lookup thumbnails 0}}" alt="{{title}}"/>
        <div class="product-body">
            <p class="product-code">{{code}}</p>
            <p class="product-title">{{title}}</p>
            <span class="product-category">{{category}}</span>
            <div class="product-meta">
                <span class="product-price">${{price}}</span>
                <span class="product-stock">Stock: {{stock}}</span>
            </div>
        </div>
    </a>
    {{/each}}
</div>